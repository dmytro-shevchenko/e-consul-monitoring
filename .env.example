# Copy to .env and fill in from your browser (DevTools → Network → external_reader request → Request Headers).
# Load with: export $(grep -v '^#' .env | xargs)  (or use a .env loader in your shell).

TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
USER_AGENT=Mozilla/5.0 (X11; Ubuntu; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0
# COOKIES=   # optional, only if Cloudflare requires it
# INTERVAL=300              # optional; poll interval seconds (60–86400)
# INSTITUTION_CODE=1000000514
# OPERATION_NAME=Оформлення закордонного паспорта   # exact match to consularInstitutionService[].name in schedule
# CONSUL_IPN_HASH=     # optional; empty = merge all consuls that list OPERATION_NAME; else one 64-char hex hash
# DRY_RUN=true          # local test: read examples/response_2.json + response_1.json instead of POST
# TELEGRAM_BOT_TOKEN=   # optional; BotFather token — alerts to TELEGRAM_CHAT_ID
# TELEGRAM_CHAT_ID=     # optional; group chat id (e.g. -100…)
# WEB_USERNAME=         # optional; with WEB_PASSWORD, protects the web UI (not shown on Settings page)
# WEB_PASSWORD=
