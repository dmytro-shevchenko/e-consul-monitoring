            "text": "{\"data\":[{\"data\":{\"consulIpnHash\":\"d949d07e1ac916a8866865e3a895b538e4f49d02b727d9dc37a6c940350b6d27\",\"nonWorkingTime\":[],\"institutionCode\":\"1000000514\",\"institutionName\":\"Генеральне консульство України в Нью-Йорку\",\"receptionCitizensTime\":[{\"workingDays\":\"п'ятниця\",\"workingHoursTo\":\"12:30\",\"workingHoursFrom\":\"09:00\"}],\"consularInstitutionService\":[{\"id\":\"4b55ca10-9058-11ef-ba53-9795a0a90f10\",\"code\":\"37\",\"name\":\"Видача витягу з Державного реєстру актів цивільного стану\"},{\"id\":\"4b649720-9058-11ef-ba53-9795a0a90f10\",\"code\":\"23\",\"name\":\"Витребування документа\"},{\"id\":\"4afbea40-9058-11ef-ba53-9795a0a90f10\",\"code\":\"24\",\"name\":\"Витребування документа, засвідченого в Україні уповноваженим органом\"},{\"id\":\"4af8dd00-9058-11ef-ba53-9795a0a90f10\",\"code\":\"25\",\"name\":\"Витребування інформації від компетентних органів України та оформлення відповідної довідки\"},{\"id\":\"4b056020-9058-11ef-ba53-9795a0a90f10\",\"code\":\"34\",\"name\":\"Внесення змін до актових записів цивільного стану, їх поновлення та анулювання\"},{\"id\":\"4af3ace0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"28\",\"name\":\"Державна реєстрація шлюбу між громадянами України\"},{\"id\":\"4ae81420-9058-11ef-ba53-9795a0a90f10\",\"code\":\"18\",\"name\":\"Довідка про належність до громадянства України\"},{\"id\":\"4ae4b8c0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"19\",\"name\":\"Довідка про неналежність до громадянства України\"},{\"id\":\"4b4b1bb0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"44\",\"name\":\"Засвідчення вірності копій документів і виписок з них\"},{\"id\":\"4b2a2630-9058-11ef-ba53-9795a0a90f10\",\"code\":\"45\",\"name\":\"Засвідчення вірності підпису на документах\"},{\"id\":\"4ada5880-9058-11ef-ba53-9795a0a90f10\",\"code\":\"7\",\"name\":\"Зняття з консульського обліку\"},{\"id\":\"4b4ec530-9058-11ef-ba53-9795a0a90f10\",\"code\":\"40\",\"name\":\"Майнова довіреність\"},{\"id\":\"4b171360-9058-11ef-ba53-9795a0a90f10\",\"code\":\"42\",\"name\":\"Немайнова довіреність\"},{\"id\":\"4b670820-9058-11ef-ba53-9795a0a90f10\",\"code\":\"21\",\"name\":\"Оформлення документів для залишення на постійне проживання за кордоном\"},{\"id\":\"4ac43870-9058-11ef-ba53-9795a0a90f10\",\"code\":\"4\",\"name\":\"Оформлення посвідчення на повернення в Україну\"},{\"id\":\"4b69a030-9058-11ef-ba53-9795a0a90f10\",\"code\":\"17\",\"name\":\"Перевірка належності до громадянства України\"},{\"id\":\"4b0252e0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"36\",\"name\":\"Повторна видача свідоцтва про реєстрацію акту цивільного стану\"},{\"id\":\"4b599aa0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"35\",\"name\":\"Повторна видача свідоцтва у разі внесення змін до актового запису цивільного стану чи його поновлення\"},{\"id\":\"4b1369e0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"43\",\"name\":\"Посвідчення заповітів\"},{\"id\":\"4b1f50c0-9058-11ef-ba53-9795a0a90f10\",\"code\":\"50\",\"name\":\"Посвідчення факту, що фізична особа є живою\"},{\"id\":\"4ade5020-9058-11ef-ba53-9795a0a90f10\",\"code\":\"6\",\"name\":\"Прийняття на консульський облік\"},{\"id\":\"4ae1d290-9058-11ef-ba53-9795a0a90f10\",\"code\":\"20\",\"name\":\"Реєстрація набуття громадянства України за народженням\"}]},\"id\":\"f3ffe8f0-9fb0-11ef-8325-a54dce92a40b\",\"registerId\":8,\"keyId\":17,\"meta\":\"****\",\"allowTokens\":[],\"createdBy\":\"bpmn-event\",\"updatedBy\":\"bpmn-event\",\"createdAt\":\"2024-11-10T22:13:02.847Z\",\"updatedAt\":\"2025-07-29T17:04:03.951Z\",\"signature\":null,\"isEncrypted\":false},{\"data\":{\"consulIpnHash\":\"8f882f1b908a91c8ed8935a1a9411dc0c929c29c8a448a884db99e690441387d\",\"nonWorkingTime\":[{\"notWorkingDateAndHoursTo\":\"2026-07-02T09:05:00.00-07:00\",\"notWorkingDateAndHoursFrom\":\"2026-07-02T09:00:00.00-07:00\"},{\"notWorkingDateAndHoursTo\":\"2026-07-02T09:10:00.00-07:00\",\"notWorkingDateAndHoursFrom\":\"2026-07-02T09:05:00.00-07:00\"},{\"notWorkingDateAndHoursTo\":\"2026-07-02T09:15:00.00-07:00\",\"no